# Kopiere diese Datei nach .env und fülle die Werte aus.
# .env wird von config.py via python-dotenv geladen und überschreibt config.yaml.

# --- Kaggle (F-01) ---------------------------------------------------------
# Ohne diese Werte nutzt der Kaggle-Adapter den lokalen CSV-Fallback
# (sources.kaggle_playerscores.local_csv_dir in config.yaml).
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- Datenbank (optional) --------------------------------------------------
# Überschreibt database.url aus config.yaml. Leer lassen für SQLite-Default.
# Beispiel Postgres (Supabase/Neon):
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=
